local function setUIVisible(state)
    uiVisible = state
    if uiVisible then
        mainFrame.Visible = true
        mainFrame.Size = UDim2.new(0, 420, 0, 0)
        tween(mainFrame, {Size = UDim2.new(0, 420, 0, 606)}, 0.25, Enum.EasingStyle.Quint)
        tabBtn.Text = "X"
        miniPlayer.Visible = false
        task.wait(0.1)
        hideTopBar()
    else
        tween(mainFrame, {Size = UDim2.new(0, 420, 0, 0)}, 0.2, Enum.EasingStyle.Quint)
        settingsFrame.Visible = false
        task.delay(0.2, function()
            if not uiVisible then mainFrame.Visible = false end
        end)
        tabBtn.Text = "M"
        miniPlayer.Visible = true
    end
end

