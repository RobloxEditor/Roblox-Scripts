local function playSong(index)
    currentIndex = index
    local song = MusicList[index]

    if currentSound then
        eqEffect.Parent = nil
        reverbEffect.Parent = nil
        currentSound:Destroy()
    end

    currentSound = Instance.new("Sound")
    currentSound.Name = "MusicPlayerSound"
    currentSound.Volume = volFill.Size.X.Scale
    currentSound.Parent = SoundService

    local success = pcall(function()
        if getgenv and writefile and getcustomasset then
            local data = game:HttpGet(song.Url)
            local ext = getUrlExtension(song.Url) or "mp3"
            local uniqueFilename = "music_" .. tostring(index) .. "_" .. tostring(math.floor(tick() * 1000)) .. "." .. ext
            writefile(uniqueFilename, data)
            currentSound.SoundId = getcustomasset(uniqueFilename)
        else
            currentSound.SoundId = song.Url
        end
    end)

    if not success then
        currentSound.SoundId = song.Url
    end

    if eqEnabled then
        eqEffect.Parent = currentSound
        reverbEffect.Parent = currentSound
    end

    currentSound.Ended:Connect(function()
        if currentSound and isPlaying then
            if repeatEnabled then
                playSong(currentIndex)
            else
                local nextIndex
                if shuffleEnabled then
                    nextIndex = math.random(1, #MusicList)
                else
                    nextIndex = currentIndex + 1
                    if nextIndex > #MusicList then nextIndex = 1 end
                end
                playSong(nextIndex)
            end
        end
    end)

    currentSound:Play()
    isPlaying = true
    playBtn.Text = "||"
    miniPlayBtn.Text = "||"
    updateNowPlaying(song.Name)
    highlightCurrent()
end

local function buildSongList(filterText)
    for _, btn in ipairs(songButtons) do btn:Destroy() end
    songButtons = {}

    for i, song in ipairs(MusicList) do
        if filterText == "" or string.find(string.lower(song.Name), string.lower(filterText)) then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 44)
            local baseColor = (i == currentIndex) and COL_PANEL_ALT or COL_PANEL
            btn.BackgroundColor3 = baseColor
            btn.AutoButtonColor = false
            btn.Text = "   - " .. song.Name
            btn.TextColor3 = COL_TEXT
            btn.TextSize = 14
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Font = Enum.Font.GothamBold
            btn.Parent = scrollFrame
            corner(btn, 10)
            local st = stroke(btn, COL_ACCENT, 1.5)
            st.Transparency = (i == currentIndex) and 0 or 1

            hoverEffect(btn, function() return baseColor end, function() return COL_PANEL_ALT end)
            btn.MouseButton1Click:Connect(function()
                playSong(i)
            end)

            table.insert(songButtons, btn)
        end
    end

    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
end

