-- ====================== HELPERS ======================
local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 10)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(70, 70, 85)
    s.Thickness = thickness or 1
    s.Transparency = 0.4
    s.Parent = parent
    return s
end

local function gradient(parent, c1, c2, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c1, c2)
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

local function tween(obj, props, time, style)
    TweenService:Create(obj, TweenInfo.new(time or 0.18, style or Enum.EasingStyle.Quad), props):Play()
end

local function hoverEffect(btn, baseColorFn, hoverColorFn)
    btn.MouseEnter:Connect(function() tween(btn, {BackgroundColor3 = hoverColorFn()}, 0.12) end)
    btn.MouseLeave:Connect(function() tween(btn, {BackgroundColor3 = baseColorFn()}, 0.12) end)
end

local function setBackgroundBlur(amount)
    local lighting = game:GetService("Lighting")
    local blur = lighting:FindFirstChild("MusicPlayerBlur")
    if amount and amount > 0 then
        if not blur then
            blur = Instance.new("BlurEffect")
            blur.Name = "MusicPlayerBlur"
            blur.Parent = lighting
        end
        blur.Size = amount
    elseif blur then
        blur:Destroy()
    end
end

local function formatTime(seconds)
    seconds = math.max(0, math.floor(seconds or 0))
    local m = math.floor(seconds / 60)
    local s = seconds % 60
    return string.format("%d:%02d", m, s)
end

local SUPPORTED_AUDIO_EXTENSIONS = {"mp3"}

local function getUrlExtension(url)
    local lowerUrl = string.lower(url)
    for _, ext in ipairs(SUPPORTED_AUDIO_EXTENSIONS) do
        if string.sub(lowerUrl, -(#ext + 1)) == "." .. ext then
            return ext
        end
    end
    return nil
end

