-- ====================== CUSTOM MP3 LINK ======================
local function decodeUrlText(str)
    str = string.gsub(str, "+", " ")
    str = string.gsub(str, "%%(%x%x)", function(hex)
        return string.char(tonumber(hex, 16))
    end)
    return str
end

local function deriveNameFromUrl(url)
    local filename = url:match("([^/]+)$") or url
    filename = decodeUrlText(filename)
    filename = filename:gsub("%.[Mm][Pp]3$", "")
    if filename == "" then filename = "Custom Song" end
    return filename
end

local function flashInvalidUrl()
    customUrlStroke.Color = COL_DANGER
    tween(customUrlStroke, {Transparency = 0}, 0.1)
    local placeholderBefore = customUrlBox.PlaceholderText
    customUrlBox.PlaceholderText = "Link must end with .mp3"
    task.delay(1.2, function()
        tween(customUrlStroke, {Transparency = 0.4}, 0.4)
        customUrlStroke.Color = Color3.fromRGB(70, 70, 85)
        customUrlBox.PlaceholderText = placeholderBefore
    end)
end

local function addCustomSong()
    local rawUrl = customUrlBox.Text
    rawUrl = rawUrl:gsub("^%s+", ""):gsub("%s+$", "")
    if rawUrl == "" then return end

    if not getUrlExtension(rawUrl) then
        flashInvalidUrl()
        return
    end

    local name = deriveNameFromUrl(rawUrl)
    table.insert(MusicList, {Name = name, Url = rawUrl})
    buildSongList(searchBox.Text)
    customUrlBox.Text = ""
    playSong(#MusicList)
end

